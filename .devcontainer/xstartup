#!/bin/bash
# .devcontainer/xstartup

# Disattiva alcune impostazioni che possono dare problemi in VNC
unset SESSION_MANAGER
unset DBUS_SESSION_BUS_ADDRESS

# Carica le risorse X (colori, font, etc.) - utile per compatibilità
xrdb $HOME/.Xresources

# Avvia il window manager XFCE4 in background
startxfce4 &

# (Alternativa: usa un window manager più leggero come Fluxbox)
# Se hai installato fluxbox invece di xfce4 nel Dockerfile:
# exec fluxbox &

# Avvia un terminale all'interno della sessione VNC (opzionale)
# xfce4-terminal &